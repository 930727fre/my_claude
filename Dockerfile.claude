FROM node:20-slim

RUN apt-get update && apt-get install -y \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Create non-root user with UID/GID matching your host (see DESIGN.md decision 8)
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd --gid ${USER_GID} claude \
    && useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash claude

USER claude
WORKDIR /home/claude

# Pre-create .claude directory: the named volume inherits this directory's
# ownership on first initialization. Without this, the docker daemon creates
# the mount point as root-owned and the claude user can't write to it.
RUN mkdir -p /home/claude/.claude

# Fake identity: lets git commit work without leaking the real GitHub identity
RUN git config --global user.email "claude@container.local" && \
    git config --global user.name "Claude (container)"

ENTRYPOINT ["/bin/bash"]
