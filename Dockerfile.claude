FROM debian:bookworm-slim

# debian:bookworm-slim has no pre-existing user at UID 1000 (unlike node:* or
# ubuntu:* images), so we can freely create our own user below without conflict.

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Create non-root user with UID/GID matching your host (see DESIGN.md decision 8)
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd --gid ${USER_GID} claude \
    && useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash claude

USER claude
WORKDIR /home/claude

# Pre-create .claude so Docker doesn't claim it as root for the CLAUDE.md bind mount.
# An empty directory has no shadowing risk (only files with content are affected by
# the volume-init trap described in DESIGN.md Decision 3).
RUN mkdir -p /home/claude/.claude

# Git identity is NOT baked here. The named volume at $HOME shadows any
# image-baked dotfile after first init (silently ignoring later edits).
# Identity is set ad-hoc inside the container on first commit. See DESIGN.md Decision 7.

ENTRYPOINT ["/bin/bash"]
