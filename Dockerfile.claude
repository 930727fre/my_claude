FROM debian:bookworm-slim

# debian:bookworm-slim has no pre-existing user at UID 1000 (unlike node:* or
# ubuntu:* images), so we can freely create our own user below without conflict.

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Create non-root user with UID/GID matching your host (see DESIGN.md decision 8)
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd --gid ${USER_GID} claude \
    && useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash claude

USER claude
WORKDIR /home/claude

# Pre-create .claude directory: the named volume inherits this directory's
# ownership on first initialization. Without this, the docker daemon creates
# the mount point as root-owned and the claude user can't write to it.
RUN mkdir -p /home/claude/.claude

# Identity for in-container commits; the suffix makes them visually distinct in `git log` on the host
RUN git config --global user.email "930727fre@gmail.com" && \
    git config --global user.name "Freddy Chuang (my_claude container)"

ENTRYPOINT ["/bin/bash"]
